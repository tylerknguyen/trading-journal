# Copy this file to .env and fill in your Webull OpenAPI credentials.
# Never put these values in app.js or any browser code.

WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_REGION=us
# Host only, no https://. The SDK adds HTTPS itself and signs this host value.
WEBULL_API_ENDPOINT=api.webull.com

# Optional. If omitted, the sync server will try to resolve the first account via the SDK.
WEBULL_ACCOUNT_ID=

WEBULL_ORDER_PAGE_SIZE=25
# Optional. Defaults to Jan 1 of the current year through today.
WEBULL_SYNC_START_DATE=
WEBULL_SYNC_END_DATE=
WEBULL_SYNC_CHUNK_DAYS=31
WEBULL_SYNC_REQUEST_DELAY_SECONDS=1.5
WEBULL_TOKEN_VERIFY_TIMEOUT_SECONDS=25
WEBULL_TOKEN_VERIFY_INTERVAL_SECONDS=5

# The local server port. Use 5173 to replace the static dev server.
PORT=5173
